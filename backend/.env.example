# Copy this file to backend/.env and update values for your machine.
# The backend auto-loads backend/.env on startup.

# Example for local MySQL (XAMPP default root with no password):
DATABASE_URL=mysql+pymysql://root:@localhost/pos_system
SECRET_KEY=change-this-to-a-random-secret-string

# Optional Flask runtime config
FLASK_ENV=development
FLASK_DEBUG=1

# Email settings (required for Forgot Password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com
